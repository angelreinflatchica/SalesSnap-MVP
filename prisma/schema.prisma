// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String       @id @default(cuid())
  mobileNumber String       @unique
  password     String
  businessName String?
  currency     String       @default("PHP")
  displayName  String?
  tagline      String?
  avatarColor  String?      @default("#16a34a")
  accountClaimed Boolean    @default(false)
  createdAt    DateTime     @default(now())
  sales        SalesEntry[]
  expenses     Expense[]
}

model SalesEntry {
  id        String   @id @default(cuid())
  userId    String
  amount    Float
  note      String?
  date      DateTime @default(now())
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Expense {
  id            String   @id @default(cuid())
  userId        String
  label         String
  amount        Float
  date          DateTime @default(now())
  createdAt     DateTime @default(now())
  expenseType   String   @default("one-time")
  spreadDays    Int      @default(1)
  dailyAmount   Float?
  spreadEndDate DateTime?
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
